# Скопируйте в переменные окружения на Render / Railway / VPS.
# Не коммитьте реальные значения в git.

# Обязательно: Postgres (Neon, Supabase, Render PostgreSQL и т.д.)
# Для Neon обычно нужен sslmode=require в строке.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public&sslmode=require"

# Обязательно: секрет подписи JWT (длинная случайная строка)
JWT_ACCESS_SECRET="сгенерируйте_openssl_rand_hex_32"

# Опционально
JWT_ACCESS_EXPIRES_SECONDS="3600"
JWT_REFRESH_EXPIRES_DAYS="14"

# Порт процесса (Render/Fly подставляют свой через PORT — можно не задавать)
PORT="3000"

# Обязательно для браузера: URL фронта на Vercel (через запятую можно несколько)
CORS_ORIGIN="https://ваш-проект.vercel.app"

# Опционально: явный bind (по умолчанию в коде 0.0.0.0)
# HOST="0.0.0.0"
