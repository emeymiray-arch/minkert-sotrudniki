# Строка подключения Neon (продакшн). Скопируйте в backend/.env.neon — файл в .gitignore.
# Должна совпадать с DATABASE_URL в Render (тот же проект Neon).
# Используйте pooled endpoint (hostname с -pooler):
#   ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
