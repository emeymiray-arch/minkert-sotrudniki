# Строка подключения Neon (продакшн). Скопируйте в backend/.env.neon — файл в .gitignore.
# Для Render используйте pooled endpoint (hostname с -pooler) и добавьте:
#   ?sslmode=require&pgbouncer=true&connection_limit=5
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
