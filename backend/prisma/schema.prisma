generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
  LOYALTY
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

model User {
  id                 String         @id @default(cuid())
  email              String         @unique
  passwordHash       String
  name               String
  role               UserRole       @default(VIEWER)
  linkedEmployeeId   String?
  linkedEmployee     Employee?      @relation(fields: [linkedEmployeeId], references: [id], onDelete: SetNull)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  refreshTokens      RefreshToken[]

  @@index([linkedEmployeeId])
}

model RefreshToken {
  id          String    @id @default(cuid())
  tokenSha256 String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Employee {
  id          String         @id @default(cuid())
  name        String
  position    String
  status      EmployeeStatus @default(ACTIVE)
  /** Секретная ссылка на публичный дневник (без логина). */
  diaryToken  String?        @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tasks       Task[]
  diaryDays   DiaryDay[]
  linkedUsers User[]
  opsProfile  OpsStaffProfile?
  opsTasks    OpsTask[]
  opsViolations OpsViolation[]
  opsContentReviews OpsContentReview[]
  opsReports  OpsReportLog[]
  opsCheckEntries OpsTaskCheckEntry[]

  @@index([name])
  @@index([status])
}

// ——— Модуль «Управление» (операционная панель салона) ———

enum OpsTimeBlock {
  MORNING
  DAY
  EVENING
  NEXT_DAY
  WEEK
}

enum OpsTaskStatus {
  PENDING
  DONE
  NOT_DONE
  PARTIAL
  OVERDUE
  NEEDS_ATTENTION
}

enum OpsViolationType {
  LATE
  LEFT_WORKPLACE
  NO_WARNING
  MISSED_REPORT
  IGNORED_TASK
  REPEAT
  OTHER
}

enum OpsReportStatus {
  PENDING
  SUBMITTED
  MISSED
  ERROR
}

enum OpsContentRole {
  STORY
  REEL
}

/** Тип журнала фиксации внутри задачи проверки. */
enum OpsTaskCheckType {
  NONE
  ATTENDANCE
  CHECKLIST
  REPORT
  GENERIC
}

enum OpsAttendanceMark {
  PRESENT
  LATE
  ABSENT
  WARNED
}

model OpsBlockConfig {
  id        String       @id @default(cuid())
  block     OpsTimeBlock @unique
  title     String
  timeStart String       @default("09:00")
  timeEnd   String       @default("18:00")
  sortOrder Int          @default(0)
  enabled   Boolean      @default(true)
  updatedAt DateTime     @updatedAt
}

model OpsCategory {
  id        String       @id @default(cuid())
  block     OpsTimeBlock
  forDate   DateTime     @db.Date
  title     String
  sortOrder Int          @default(0)
  pinned    Boolean      @default(false)
  tasks     OpsTask[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([block, forDate])
}

model OpsTask {
  id           String        @id @default(cuid())
  block        OpsTimeBlock
  categoryId   String?
  category     OpsCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  /** Метка для сортировки (без отдельных визуальных секций). */
  categoryLabel String       @default("")
  title        String
  description  String        @default("")
  sortOrder    Int           @default(0)
  forDate      DateTime      @db.Date
  dueAt        DateTime?
  status       OpsTaskStatus @default(PENDING)
  pinned       Boolean       @default(false)
  recurring    Boolean       @default(false)
  templateKey  String?
  assigneeId   String?
  assignee     Employee?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  markedAt     DateTime?
  markedByName String?
  checkType    OpsTaskCheckType @default(NONE)
  comments     OpsTaskComment[]
  notes        OpsTaskNote[]
  checkEntries OpsTaskCheckEntry[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([block, forDate])
  @@index([forDate])
  @@index([categoryId])
  @@index([assigneeId])
  @@index([status])
  @@index([checkType])
}

/** Журнал: результат проверки по сотруднику внутри задачи. */
model OpsTaskCheckEntry {
  id               String             @id @default(cuid())
  taskId           String
  task             OpsTask            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  employeeId       String
  employee         Employee           @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  recordDate       DateTime           @db.Date
  attendanceMark   OpsAttendanceMark?
  checklistOpened  Boolean?
  checklistDone    Boolean?
  checklistIgnored Boolean?
  reportSubmitted  Boolean?
  reportError      Boolean?
  reportNeedsFix   Boolean?
  comment          String             @default("")
  extraNote        String             @default("")
  flagViolation    Boolean            @default(false)
  recordedByName   String             @default("")
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@unique([taskId, employeeId, recordDate])
  @@index([employeeId, recordDate])
  @@index([taskId, recordDate])
}

model OpsTaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      OpsTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String?
  authorName String  @default("")
  body      String
  createdAt DateTime @default(now())

  @@index([taskId])
}

model OpsTaskNote {
  id        String   @id @default(cuid())
  taskId    String
  task      OpsTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model OpsStaffProfile {
  id              String   @id @default(cuid())
  employeeId      String   @unique
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  schedule        String   @default("")
  disciplineLevel Int      @default(100)
  warningsCount   Int      @default(0)
  preferences     String   @default("")
  workStyle       String   @default("")
  traits          String   @default("")
  managerNotes    String   @default("")
  clientAttitude  String   @default("")
  qualityNotes    String   @default("")
  updatedAt       DateTime @updatedAt
}

model OpsViolation {
  id          String           @id @default(cuid())
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        OpsViolationType @default(OTHER)
  description String           @default("")
  occurredAt  DateTime         @default(now())
  warned      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([employeeId])
  @@index([occurredAt])
}

model OpsContentReview {
  id           String         @id @default(cuid())
  employeeId   String
  employee     Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  roleType     OpsContentRole @default(STORY)
  title        String         @default("")
  publishedAt  DateTime?
  reviewDate   DateTime       @db.Date
  reach        Int?
  engagement   Float?
  views        Int?
  visualScore  Int?
  brandMatch   Boolean?
  qualityNote  String         @default("")
  checked      Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([employeeId])
  @@index([reviewDate])
}

model OpsReportLog {
  id          String          @id @default(cuid())
  employeeId  String?
  employee    Employee?       @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  formKey     String
  reportDate  DateTime        @db.Date
  status      OpsReportStatus @default(PENDING)
  payload     Json?
  errorNote   String          @default("")
  submittedAt DateTime?
  createdAt   DateTime        @default(now())

  @@index([reportDate])
  @@index([employeeId])
}

model OpsActivityLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  userId     String?
  userName   String   @default("")
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}

model OpsSettings {
  id                    String   @id @default("default")
  googleFormMappings    Json?
  formsWebhookNote      String   @default("")
  updatedAt             DateTime @updatedAt
}

model OpsProblem {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([resolved, createdAt])
}

/** Финансы: показатели по дням (выручка, расходы, скидки, ЗП, клиентки). */
model OpsFinanceDay {
  id          String   @id @default(cuid())
  date        DateTime @unique @db.Date
  revenue     Int      @default(0)
  revenueNoDiscount Int @default(0)
  expenses    Int      @default(0)
  discounts   Int      @default(0)
  salary      Int      @default(0)
  clientCount Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LoyaltyClient {
  id              String         @id @default(cuid())
  name            String
  phone           String
  phoneNormalized String         @unique
  stamps          LoyaltyStamp[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([name])
  @@index([phone])
}

model LoyaltyStamp {
  id         String        @id @default(cuid())
  clientId   String
  client     LoyaltyClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  slot       Int
  masterName String
  stampedAt  DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@unique([clientId, slot])
  @@index([clientId, stampedAt])
}

model Task {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  title       String
  description String   @default("")
  taskDate    DateTime @db.Date
  mon         Int      @default(0)
  tue         Int      @default(0)
  wed         Int      @default(0)
  thu         Int      @default(0)
  fri         Int      @default(0)
  sat         Int      @default(0)
  sun         Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([taskDate])
}

enum DiaryLineState {
  EMPTY
  CHECK
  CROSS
}

model DiaryDay {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime    @db.Date
  lines      DiaryLine[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([employeeId, date])
  @@index([employeeId])
}

model DiaryLine {
  id         String         @id @default(cuid())
  diaryDayId String
  diaryDay   DiaryDay       @relation(fields: [diaryDayId], references: [id], onDelete: Cascade)
  sortOrder  Int            @default(0)
  label      String         @default("")
  state      DiaryLineState @default(EMPTY)

  @@index([diaryDayId])
}
